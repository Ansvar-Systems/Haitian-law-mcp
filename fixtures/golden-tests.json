{
  "$schema": "./golden-tests.schema.json",
  "version": "1.0",
  "mcp_name": "Haitian Law MCP",
  "description": "Golden contract tests for the Haitian Law MCP",
  "tests": [
    {
      "id": "HT-001",
      "category": "search",
      "description": "Search for 'travail' returns results from Code du travail 1961",
      "tool": "search_legislation",
      "input": {
        "query": "travail",
        "limit": 5
      },
      "assertions": {
        "result_not_empty": true,
        "min_results": 1,
        "text_not_empty": true
      }
    },
    {
      "id": "HT-002",
      "category": "search",
      "description": "Search for 'constitution' returns results from 1987 Constitution",
      "tool": "search_legislation",
      "input": {
        "query": "constitution",
        "limit": 5
      },
      "assertions": {
        "result_not_empty": true,
        "min_results": 1,
        "text_not_empty": true
      }
    },
    {
      "id": "HT-003",
      "category": "negative",
      "description": "Negative test: non-existent law returns gracefully",
      "tool": "get_provision",
      "input": {
        "document_id": "NONEXISTENT_LAW_999",
        "provision_ref": "art999"
      },
      "assertions": {
        "handles_gracefully": true
      }
    }
  ]
}
